@*@model IEnumerable<mYPMS.Models.tTraffic>*@
@using NonFactors.Mvc.Grid;
@{
    ViewData["Title"] = "گزارش";
}
@section Head
    {
    <link rel="stylesheet" href="~/lib/pdp/css/persianDatepicker-default.css" asp-append-version="false" />
}
<div class="w3-container">
    <!--BEGIN Title and Bar-->
    <div class="w3-display-container" style="height:70px;">
        <div class="w3-display-left">
            <a asp-controller="Home" asp-action="Index"><i class="fa fa-arrow-circle-left w3-xxxlarge w3-text-green w3-hover-text-lime"></i></a>
        </div>
        <div class="w3-display-middle">
            <h1 class="w3-text-black"><b>@ViewData["Title"]</b></h1>
        </div>
        <div class="w3-display-right">
            <i id="btExport" class="fa fa-file-excel-o w3-xxxlarge w3-text-red w3-hover-text-lime" style="cursor:pointer"></i>
        </div>
    </div>
    <!--END Title and Bar-->
    <!--BEGIN Search Bar-->
    <form id="formFilter" asp-action="Index" asp-controller="Report" method="get">
        <div class="w3-container w3-padding-large">
            <div class="w3-container w3-card-4">
                <div class="w3-third w3-right w3-padding-large">
                    <div class="w3-row">
                        <div class="w3-quarter w3-right"><lable>پارکینگ</lable></div>
                        <div class="w3-threequarter"><select id="selectParking" class="w3-select w3-round"><option selected value=0>همه پارکینگ ها</option></select></div>
                    </div>
                </div>
                <div class="w3-third w3-right w3-padding-large">
                    <div class="w3-row">
                        <div class="w3-quarter w3-right"><lable>دروازه</lable></div>
                        <div class="w3-threequarter"><select id="selectGate" class="w3-select w3-round"><option selected value=0>همه دروازه ها</option></select></div>
                    </div>
                </div>
                <div class="w3-third w3-right w3-padding-large">
                    <div class="w3-row">
                        <div class="w3-quarter w3-right"><lable>وضعیت</lable></div>
                        <div class="w3-threequarter">
                            <select id="selectStatus" class="w3-select w3-round">
                                <option selected value=0>همه وضعیت ها</option>
                                <option value=1>وارد شده</option>
                                <option value=2>خارج شده</option>
                                <option value=4>حذف شده</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="w3-quarter w3-right w3-padding-large">
                    <div class="w3-row">
                        <div class="w3-quarter w3-right"><lable>از تاریخ</lable></div>
                        <div class="w3-threequarter">
                            <input id="dateFrom" autocomplete="off" class="w3-input w3-round" />
                        </div>
                    </div>
                </div>
                <div class="w3-quarter w3-right w3-padding-large">
                    <div class="w3-row">
                        <div class="w3-quarter w3-right"><lable>تا تاریخ</lable></div>
                        <div class="w3-threequarter">
                            <input id="dateTo" autocomplete="off" class="w3-input w3-round" />
                        </div>
                    </div>
                </div>
                <div class="w3-quarter w3-right w3-padding-large">
                    <div class="w3-row">
                        <div class="w3-quarter w3-right"><lable>پلاک</lable></div>
                        <div class="w3-threequarter">
                            <input id="license" class="w3-input w3-round" />
                        </div>
                    </div>
                </div>
                <div class="w3-quarter w3-right w3-padding-large">
                    <div class="w3-row">
                        <div class="w3-quarter w3-right"><lable>شماره کارت</lable></div>
                        <div class="w3-threequarter">
                            <input id="tag" class="w3-input w3-round" />
                        </div>
                    </div>
                </div>
                <div class="w3-row w3-padding-large">
                    <div class="w3-half w3-padding-large">
                        <button id="btClear" class="w3-button w3-block w3-round w3-2021-raspberry-sorbet w3-ripple w3-hover-lime">پاک کردن فرم جستجو</button>
                    </div>
                    <div class="w3-half w3-padding-large">
                        <input type="button" id="btFilter" class="w3-button w3-block w3-round w3-2021-mint w3-ripple w3-hover-lime" value="جستجو" />
                    </div>
                </div>
            </div>
        </div>
    </form>
    <!--END Search Bar-->
    <!--BEGIN Data Table-->
    <div class="w3-container w3-padding-large">
        @Html.AjaxGrid(Url.Action("Index"))
    </div>
    <!--END Data Table-->
    <!--START MODAL DETAIL-->
    <div id="modalDetail" class="w3-modal" style="padding-top:0px;">
        <div class="w3-modal-content w3-card-4" style="font-weight:bold;">
            <header class="w3-container w3-light-gray">
                <div class="w3-display-topleft">
                    <span onclick="$('#modalDetail').hide();" class="w3-button fa fa-window-close w3-xlarge"></span>
                </div>
                <h2 id="modalTitle" class="w3-center"><b>جزئیات تردد</b></h2>
            </header>
            <input type="hidden" id="modalId" />
            <div class="w3-container">
                <div class="w3-half w3-center">
                    <h3><b>تصویر ورود</b></h3>
                    <img id="modalImageEn" class="w3-image w3-padding-small" onerror="this.src='/imgs/cnf404.png'" />
                    <img id="modalPlateEn" class="w3-image" onerror="this.src='/imgs/pnf404.png'" />
                </div>
                <div class="w3-half w3-center">
                    <h3><b>تصویر خروج</b></h3>
                    <img id="modalImageEx" class="w3-image w3-padding-small" onerror="this.src='/imgs/cnf404.png'" />
                    <img id="modalPlateEx" class="w3-image" onerror="this.src='/imgs/pnf404.png'" />
                </div>
            </div>
            <div class="w3-container w3-padding">
                <div class="w3-col s6 m4 l3 w3-right">
                    <span class="w3-right"><lable>زمان ورود: </lable></span>
                    <label id="xEntryDateTime"></label>
                </div>
                <div class="w3-col s6 m4 l3 w3-right">
                    <span class="w3-right"><lable>زمان خروج: </lable></span>
                    <label id="xDepartureDateTime"></label>
                </div>
                <div class="w3-col s6 m4 l3 w3-right">
                    <span class="w3-right"><lable>پلاک ورود: </lable></span>
                    <label id="xLicencePlateEn"></label>
                </div>
                <div class="w3-col s6 m4 l3 w3-right">
                    <span class="w3-right"><lable>پلاک خروج: </lable></span>
                    <label id="xLicencePlateEx"></label>
                </div>
                <div class="w3-col s6 m4 l3 w3-right">
                    <span class="w3-right"><lable>مبلغ: </lable></span>
                    <label id="xPaid"></label>
                </div>
                <div class="w3-col s6 m4 l3 w3-right">
                    <span class="w3-right"><lable>تعرفه: </lable></span>
                    <label id="xTariff"></label>
                </div>
                <div class="w3-col s6 m4 l3 w3-right">
                    <span class="w3-right"><lable>شماره کارت: </lable></span>
                    <label id="xTagId"></label>
                </div>
            </div>
            <footer class="w3-container w3-padding-large w3-light-gray w3-center">
                <h3><b>تغییر وضعیت به</b></h3>
                <div class="w3-third w3-padding-large">
                    <h3>
                        <button id="modalDelete" class="w3-container w3-red w3-button w3-round w3-hover-lime" style="width:100%;height:70px;display:grid"><b>حذف شده</b></button>
                    </h3>
                </div>
                <div class="w3-third w3-padding-large">
                    <h3>
                        <button id="modalDeparture" class="w3-container w3-orange w3-button w3-round w3-hover-lime" style="width: 100%; height: 70px; display: grid"><b>خارج شده</b></button>
                    </h3>
                </div>
                <div class="w3-third w3-padding-large">
                    <h3>
                        <button id="modalEnter" class="w3-container w3-green w3-button w3-round w3-hover-lime" style="width: 100%; height: 70px; display: grid"><b>وارد شده</b></button>
                    </h3>
                </div>
            </footer>
        </div>
    </div>
    <!--END MODAL DETAIL-->
</div>
@section Scripts
{
<script src="~/js/Report.js"></script>
<script src="~/lib/pdp/js/persianDatepicker.min.js"></script>
<script type="text/javascript">
    var parkings = [];
    $.getJSON(
        "/Report/getParkingWithGates",
        function (data) {
            parkings = data;
            $("#selectParking option:gt(0)").remove();
            $.each(data, function () {
                $("#selectParking").append($("<option></option>").attr("value", this.xId).text(this.xTitle));
            });
        }
    );
    $("#selectParking").on("change", function () {
        $("#selectGate option:gt(0)").remove();
        if ($("#selectParking").val() === 0) {
            $("#selectParking").val($("#selectParking option:first").val());
            return;
        }
        let gates = parkings.filter(g => g.xId === $("#selectParking").val())[0].xGates;
        $.each(gates, function () {
            $("#selectGate").append($("<option></option>").attr("value", this.xId).text(this.xName));
        });
    });
    let pd = new persianDate();
    $("#dateFrom").persianDatepicker({
        formatDate: "YYYY/0M/0D",
        endDate: pd.now().toString("YYYY/MM/DD"),
    });
    $("#dateTo").persianDatepicker({
        formatDate: "YYYY/0M/0D",
        endDate: pd.now().toString("YYYY/MM/DD"),
    });
    $("#btFilter").click(function () {
        const grid = new MvcGrid(document.querySelector(".mvc-grid"));
        $("#selectParking").val() != 0 ? grid.url.searchParams.set("parking", $("#selectParking").val()) : grid.url.searchParams.delete("parking");
        $("#selectGate").val() != 0 ? grid.url.searchParams.set("gate", $("#selectGate").val()) : grid.url.searchParams.delete("gate");
        $("#selectStatus").val() != 0 ? grid.url.searchParams.set("status", $("#selectStatus").val()) : grid.url.searchParams.delete("status");
        $("#dateFrom").val() ? grid.url.searchParams.set("dateFrom", $("#dateFrom").val()) : grid.url.searchParams.delete("dateFrom");
        $("#dateTo").val() ? grid.url.searchParams.set("dateTo", $("#dateTo").val()) : grid.url.searchParams.delete("dateTo");
        $("#tag").val() ? grid.url.searchParams.set("tag", $("#tag").val()) : grid.url.searchParams.delete("tag");
        $("#license").val() ? grid.url.searchParams.set("license", $("#license").val()) : grid.url.searchParams.delete("license");
        grid.reload();
    });
    $("#btExport").click(function () {
        let url = "/Report/Export?";
        url += $("#selectParking").val() != 0 ? "&parking=" + $("#selectParking").val() : "";
        url += $("#selectGate").val() != 0 ? "&gate=" + $("#selectGate").val() : "";
        url += $("#selectStatus").val() != 0 ? "&status=" + $("#selectStatus").val() : "";
        url += $("#dateFrom").val() ? "&dateFrom=" + $("#dateFrom").val() : "";
        url += $("#dateTo").val() ? "&dateTo=" + $("#dateTo").val() : "";
        url += $("#tag").val() ? "&tag=" + $("#tag").val() : "";
        url += $("#license").val() ? "&license=" + $("#license").val() : "";
        let a = document.createElement('a');
        a.setAttribute('href', url);
        a.setAttribute('target', "_blank");
        var ev = document.createEvent("MouseEvents");
        ev.initMouseEvent("click", true, false, self, 0, 0, 0, 0, 0, false, false, false, false, 0, null);
        a.dispatchEvent(ev);
    });
</script>
}