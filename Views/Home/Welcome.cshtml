@{
    ViewData["Title"] = "خوش آمدید";
}
<!--BEGIN Title-->
<div class="w3-container">
    <div class="w3-display-container" style="height:70px;">
        <div class="w3-display-middle">
            <h1 class="w3-text-black"><b>@ViewData["Title"]</b></h1>
        </div>
    </div>
</div>
<!--END Title-->
<!--BEGIN Body-->
<div class="w3-container w3-padding-large">
    <div class="w3-container w3-half" style="margin:auto;float:none;">
        <div class="w3-card-4">
            <form asp-controller="Home" asp-action="Welcome" method="get" id="formWelcome">
                <input type="hidden" id="pid" name="pid" />
                <input type="hidden" id="gid" name="gid"/>
                <header class="w3-container"></header>
                <div class="w3-container w3-padding-large">
                    <div class="w3-cell-row w3-container w3-padding-large">
                        <div class="w3-quarter w3-right w3-cell"><label>انتخاب پارکینگ</label></div>
                        <div class="w3-threequarter w3-cell">
                            <select id="selectParking" class="w3-select w3-round">
                                <option disabled selected value=0>انتخاب پارکینگ</option>
                            </select>
                        </div>
                    </div>
                    <div class="w3-cell-row w3-container w3-padding-large">
                        <div class="w3-quarter w3-right"><label>انتخاب دروازه</label></div>
                        <div class="w3-threequarter w3-cell">
                            <select id="selectGate" class="w3-select w3-round">
                                <option disabled selected value=0>انتخاب دروازه</option>
                            </select>
                        </div>
                    </div>
                    <div class="w3-container w3-center w3-padding-large">
                        <div class="w3-third">
                            <input class="w3-radio" type="radio" name="direction" value="1" disabled /><label>&nbsp;&nbsp;ورودی</label>
                        </div>
                        <div class="w3-third">
                            <input class="w3-radio" type="radio" name="direction" value="2" disabled /><label>&nbsp;&nbsp;خروجی</label>
                        </div>
                        <div class="w3-third">
                            <input class="w3-radio" type="radio" name="direction" value="3" disabled /><label>&nbsp;&nbsp;ورودی و خروجی</label>
                        </div>
                    </div>
                </div>
                <footer class="w3-container w3-center">
                    <button id="save" class="w3-button w3-green w3-hover-lime w3-round" style="width:70%;">ورود</button>
                </footer>
            </form>
        </div>
    </div>
</div>
<!--END Body-->
@section Scripts
    {
    <script type="text/javascript">
        var parkings = [];
        var gates = [];
        $.getJSON(
            "/Home/getParkingWithGates",
            function (data) {
                parkings = data;
                $("#selectParking option:gt(0)").remove();
                $.each(data, function () {
                    $("#selectParking").append($("<option></option>").attr("value", this.xId).text(this.xTitle));
                });
            }
        );
        $("#selectParking").on("change", function () {
            $("#selectGate option:gt(0)").remove();
            if ($("#selectParking").val() === 0) {
                $("#selectParking").val($("#selectParking option:first").val());
                return;
            }
            gates = parkings.filter(g => g.xId === $("#selectParking").val())[0].xGates;
            $.each(gates, function () {
                $("#selectGate").append($("<option></option>").attr("value", this.xId).text(this.xName));
            });
        });
        $("#selectGate").on("change", function () {
            $("input[name=direction]").prop("disabled", true);
            $("input[name=direction]").prop("checked", false);
            let dir = gates.filter(g => g.xId == $("#selectGate").val())[0].xDirection;
            if (dir == 1 || dir == 2) $("input[name=direction][value=" + dir + "]").prop("disabled", false);
            else $("input[name=direction]").prop("disabled", false);
            $("input[name=direction][value=" + dir + "]").prop("checked", true);
        });
        $("#save").on("click", function () {
            $("#pid").val($("#selectParking").val());
            $("#gid").val($("#selectGate").val());
            $("#formWelcome").submit();
        });
    </script>
}