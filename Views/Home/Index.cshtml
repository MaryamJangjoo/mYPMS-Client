@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "خانه";
}

<div class="w3-row">
    <div class="w3-col" style="width:80%">
        <partial name="_partialVideo" />
        <partial name="_partialTagInput" />
        <div id="history" class="w3-row w3-padding w3-margin-right w3-margin-left"></div>
    </div>
    <div class="w3-col" style="width:20%">
        <partial name="_partialLastCarCard" />
    </div>
</div>
<!--START MODAL TAG EDIT-->
<div id="modalTraffic" class="w3-modal">
    <div class="w3-modal-content w3-card-4">
        <header class="w3-container w3-light-gray">
            <div class="w3-display-topleft">
                <span onclick="$('#modalTraffic').hide();" class="w3-button fa fa-window-close w3-xlarge"></span>
            </div>
            <h2 id="modalTitle">ثبت تردد</h2>
        </header>
        <form id="formTraffic">
            <input type="hidden" id="id" name="id" />
            <div class="w3-container w3-padding">
                <div class="w3-half w3-center">
                    <img id="modalImage" class="w3-image" onerror="this.src='/imgs/cnf404.png'" />
                </div>
                <div class="w3-half">
                    <b>
                        <span class="w3-quarter w3-right"><lable>شماره کارت</lable></span>
                        <span class="w3-threequarter"><label id="xTagId"></label></span><br />
                        <span class="w3-quarter w3-right"><lable>زمان ورود</lable></span>
                        <span class="w3-threequarter"><label id="xEntryDateTime"></label></span><br />
                        <span class="w3-quarter w3-right"><lable>زمان خروج</lable></span>
                        <span class="w3-threequarter"><label id="xDepartureDateTime"></label></span><br />
                        <span class="w3-quarter w3-right"><lable>پلاک ورود</lable></span>
                        <span class="w3-threequarter"><input id="xLicencePlateEn" type="text" maxlength="20" class="w3-input"></span><br />
                        <span class="w3-quarter w3-right"><lable>پلاک خروج</lable></span>
                        <span class="w3-threequarter"><input id="xLicencePlateEx" type="text" maxlength="20" class="w3-input"></span><br />
                        <span class="w3-quarter w3-right"><lable>مبلغ</lable></span>
                        <span class="w3-threequarter"><label id="xPaid"></label></span><br />
                        <span class="w3-quarter w3-right"><lable>تعرفه</lable></span>
                        <span class="w3-threequarter"><label id="xTariff"></label></span>
                        <img id="modalPlateEn" class="w3-image w3-padding" onerror="this.src='/imgs/pnf404.png'" />
                        <img id="modalPlateEx" class="w3-image w3-padding" onerror="this.src='/imgs/pnf404.png'" />
                    </b>
                </div>
            </div>
        </form>
        <footer class="w3-container w3-padding-large w3-light-gray">
            <div class="w3-third w3-padding-large">
                <h3>
                    <b>
                        <button id="modalCancel" class="w3-container w3-center w3-red w3-button w3-round w3-hover-lime" style="width:100%;height:70px;display:grid">انصراف</button>
                    </b>
                </h3>
            </div>
            <div class="w3-third w3-padding-large">
                <h3>
                    <b>
                        <button id="modalDelete" class="w3-container w3-center w3-orange w3-button w3-round w3-hover-lime" style="width: 100%; height: 70px; display: grid">درخواست حذف</button>
                    </b>
                </h3>
            </div>
            <div class="w3-third w3-padding-large">
                <h3>
                    <b>
                        <button id="modalSubmit" class="w3-container w3-center w3-green w3-button w3-round w3-hover-lime" style="width: 100%; height: 70px; display: grid"></button>
                    </b>
                </h3>
            </div>
        </footer>
    </div>
</div>
<!--END MODAL TAG EDIT-->
@section Scripts
{
    <script type="text/javascript">
        var dir = @(HttpContextAccessor.HttpContext!.Session.GetInt32("dir")!.Value);
        var videoSettings = @Html.Raw(TempData["VideoSettings"]);
        $.blockUI();
    </script>
    <script src="~/lib/vp/jsBase/lib/md5.js"></script>
    <script src="~/lib/vp/module/streamDrawer.js"></script>
    <script src="~/lib/vp/module/public.js"></script>
    <script src="~/lib/vp/module/workerManager.js"></script>
    <script src="~/lib/vp/module/WebsocketServer.js"></script>
    <script src="~/lib/vp/module/ivs.js"></script>
    <script src="~/lib/vp/module/mp4remux.js"></script>
    <script src="~/lib/vp/module/videoMediaSource.js"></script>
    <script src="~/lib/vp/module/Sylvester.js"></script>
    <script src="~/lib/vp/module/WebGLCanvas.js"></script>
    <script src="~/lib/vp/module/playerControl.js"></script>
    <script src="~/lib/vp/module/Decode/ffmpegasm.js"></script>
    <script src="~/js/HomeIndex.js"></script>
}